{
  "servers": [
    {
      "name": "Production Server 1",
      "ip": "192.168.1.100",
      "username": "admin",
      "scripts": [
        "C:\\apps\\civic-system\\run-all-servers.bat"
      ]
    },
    {
      "name": "Production Server 2",
      "ip": "192.168.1.101",
      "username": "admin",
      "scripts": [
        "C:\\apps\\civic-system\\run-all-servers.bat"
      ]
    },
    {
      "name": "Development Server",
      "ip": "192.168.1.102",
      "username": "dev",
      "scripts": [
        "C:\\dev\\civic-system\\run-all-servers.bat"
      ]
    }
  ],
  "essential_services": [
    {
      "name": "MongoDB",
      "command": "mongod",
      "args": "--dbpath C:\\data\\db",
      "port": 27017,
      "required": true
    },
    {
      "name": "Backend API",
      "command": "npm start",
      "workdir": "backend",
      "port": 5005,
      "required": true
    },
    {
      "name": "Google ViT Server",
      "command": "python google_vit_server.py",
      "workdir": "local-ai-server",
      "port": 5002,
      "required": true
    },
    {
      "name": "Frontend",
      "command": "npm start",
      "workdir": ".",
      "port": 3000,
      "required": true
    }
  ],
  "optional_services": [
    {
      "name": "Your Google ViT Model",
      "command": "python local_vit_server.py",
      "workdir": "local-ai-server",
      "port": 5006,
      "description": "Alternative ViT server using your local model files"
    }
  ],
  "removed_overlapping_services": [
    {
      "name": "AI Server (LLaMA)",
      "reason": "Not needed for Google ViT functionality",
      "port": 5001
    },
    {
      "name": "ViT Vision Server (Duplicate)",
      "reason": "Overlaps with google_vit_server.py",
      "port": 5002
    }
  ],
  "port_summary": {
    "3000": "Frontend (React Website)",
    "5005": "Backend API (Node.js)",
    "5002": "Google ViT Server (Hugging Face Model)",
    "5006": "Your Google ViT Server (Local Model Files)",
    "27017": "MongoDB Database"
  }
}